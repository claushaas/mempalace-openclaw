{
	"plugins": {
		"entries": {
			"active-memory": {
				"config": {
					"allowedChatTypes": ["direct"],
					"enabled": true,
					"logging": true,
					"maxSummaryChars": 220,
					"persistTranscripts": true,
					"promptStyle": "recall-heavy",
					"queryMode": "recent",
					"timeoutMs": 15000,
					"transcriptDir": "mempalace-stage5"
				},
				"enabled": true
			},
			"claw-context-mempalace": {
				"config": {
					"includeMemoryPromptAddition": true,
					"maxArtifactLines": 40,
					"maxContextTokens": 1200,
					"maxEntries": 6,
					"minScore": 0.15
				},
				"enabled": true
			},
			"memory-mempalace": {
				"config": {
					"args": ["-m", "mempalace.mcp_server"],
					"command": "/absolute/path/to/mempalace/.venv/bin/python",
					"cwd": "/absolute/path/to/mempalace",
					"defaultResultLimit": 8,
					"defaultTokenBudget": 1200,
					"timeoutMs": 5000,
					"transport": "stdio"
				},
				"enabled": true
			}
		},
		"slots": {
			"contextEngine": "claw-context-mempalace",
			"memory": "memory-mempalace"
		}
	}
}
