{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"exactOptionalPropertyTypes": true,
		"isolatedModules": true,
		"lib": ["ES2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2023",
		"verbatimModuleSyntax": true
	}
}
